generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  emailVerified       Boolean  @default(false) @map("email_verified")
  role                UserRole @default(CLIENT)
  image               String?
  phoneNumber         String?  @unique @map("phone_number")
  phoneNumberVerified Boolean? @map("phone_number_verified")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessions     Sessions[]
  accounts     Accounts[]
  members      Members[]
  invitations  Invitations[]
  appointments Appointments[]

  @@map("users")
}

model Sessions {
  id                   String   @id @default(cuid())
  expiresAt            DateTime @map("expires_at")
  token                String   @unique
  ipAddress            String?  @map("ip_address")
  userAgent            String?  @map("user_agent")
  userId               String   @map("user_id")
  activeOrganizationId String?  @map("active_organization_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users Users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Accounts {
  id                    String    @id @default(cuid())
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users Users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

model Verifications {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verifications")
}

// ---- WITH ORGANIZATION -------------------------------------------------------------------------------

model Organizations {
  id               String                  @id @default(cuid())
  name             String
  slug             String                  @unique
  stripeCustomerId String?                 @map("stripe_customer_id")
  accessState      OrganizationAccessState @default(GRACE) @map("access_state")
  gracePausedAt    DateTime?               @map("grace_paused_at")
  metadata         String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members                         Members[]
  invitations                     Invitations[]
  establishments                  Establishments?
  professionals                   Professionals[]
  services                        Services[]
  professionalServices            ProfessionalServices[]
  professionalAvailabilities      ProfessionalAvailabilities[]
  appointments                    Appointments[]
  establishmentCommissionDefaults EstablishmentCommissionDefault[]
  professionalCommissionRules     ProfessionalCommissionRule[]
  commissionEntries               CommissionEntry[]
  auditLogs                       AuditLogs[]

  @@map("organizations")
}

model Members {
  id             String     @id @default(cuid())
  organizationId String     @map("organization_id")
  userId         String     @map("user_id")
  role           MemberRole @default(PROFESSIONAL)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users         Users          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizations Organizations  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  professionals Professionals?

  @@index([organizationId])
  @@index([userId])
  @@map("members")
}

model Invitations {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  email          String
  role           String?
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime         @map("expires_at")
  inviterId      String           @map("inviter_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organizations Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users         Users         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitations")
}

model Subscriptions {
  id                   String    @id @default(cuid())
  plan                 String
  referenceId          String    @map("reference_id")
  status               String    @default("incomplete")
  stripeCustomerId     String?   @map("stripe_customer_id")
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  periodStart          DateTime? @map("period_start")
  periodEnd            DateTime? @map("period_end")
  cancelAtPeriodEnd    Boolean?  @default(false) @map("cancel_at_period_end")
  cancelAt             DateTime? @map("cancel_at")
  canceledAt           DateTime? @map("canceled_at")
  endedAt              DateTime? @map("ended_at")
  seats                Int?
  trialStart           DateTime? @map("trial_start")
  trialEnd             DateTime? @map("trial_end")
  billingInterval      String?   @map("billing_interval")
  stripeScheduleId     String?   @map("stripe_schedule_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("subscriptions")
}

model Establishments {
  id              String  @id @default(cuid())
  organizationId  String  @unique @map("organization_id")
  name            String
  slug            String  @unique
  cnpj            String
  description     String
  address         String
  city            String
  state           String
  zipCode         String  @map("zip_code")
  latitude        Decimal
  longitude       Decimal
  businessHours   Json    @map("business_hours")
  isActive        Boolean @default(true) @map("is_active")
  phone           String?
  logoStorageKey  String? @map("logo_storage_key")
  coverStorageKey String? @map("cover_storage_key")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizations Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("establishments")
}

model Professionals {
  id               String  @id @default(cuid())
  organizationId   String  @map("organizationId")
  memberId         String  @unique @map("member_id")
  name             String
  bio              String
  isActive         Boolean @default(true) @map("is_active")
  avatarStorageKey String? @map("avatar_storage_key")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizations               Organizations                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members                     Members                      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  professionalServices        ProfessionalServices[]
  professionalAvailabilities  ProfessionalAvailabilities[]
  appointments                Appointments[]
  professionalCommissionRules ProfessionalCommissionRule[]
  commissionEntries           CommissionEntry[]

  @@map("professionals")
}

model Services {
  id              String  @id @default(cuid())
  organizationId  String  @map("organization_id")
  name            String
  description     String
  durationMinutes Int     @map("duration_minutes")
  priceCents      Int     @map("price_cents")
  isActive        Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organizations               Organizations                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  professionalServices        ProfessionalServices[]
  appointments                Appointments[]
  professionalCommissionRules ProfessionalCommissionRule[]
  commissionEntries           CommissionEntry[]

  @@map("services")
}

model ProfessionalServices {
  id             String @id @default(cuid())
  professionalId String @map("professional_id")
  organizationId String @map("organization_id")
  serviceId      String @map("service_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  professionals Professionals @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  services      Services      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  organizations Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("professional_services")
}

model ProfessionalAvailabilities {
  id             String @id @default(cuid())
  professionalId String @map("professional_id")
  organizationId String @map("organization_id")
  dayOfWeek      Int    @map("day_of_week")
  startTime      String @map("start_time")
  endTime        String @map("end_time")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  professionals Professionals @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  organizations Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("professional_availabilities")
}

model Appointments {
  id             String            @id @default(cuid())
  userId         String            @map("user_id")
  organizationId String            @map("organization_id")
  professionalId String            @map("professional_id")
  serviceId      String            @map("service_id")
  startsAt       DateTime          @map("starts_at")
  endsAt         DateTime          @map("ends_at")
  status         AppointmentStatus @default(PENDING)
  notes          String?

  // SNAPSHOT
  serviceName            String @map("service_name")
  serviceDurationMinutes Int    @map("service_duration_minutes")
  servicePriceCents      Int    @map("service_price_cents")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users             Users             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizations     Organizations     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  professionals     Professionals     @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  services          Services          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  commissionEntries CommissionEntry[]

  @@map("appointments")
}

model EstablishmentCommissionDefault {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  domain         CommissionDomain
  type           CommissionType
  value          Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organizations Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, domain])
  @@map("establishment_commission_default")
}

model ProfessionalCommissionRule {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  professionalId String           @map("professional_id")
  domain         CommissionDomain
  type           CommissionType
  value          Int
  // TODO: Add productId
  serviceId      String?          @map("service_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organizations Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  professionals Professionals @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  // TODO: Add product relation
  services      Services?     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // TODO: Add productId
  @@unique([professionalId, domain, serviceId])
  @@index([organizationId, professionalId])
  @@map("professional_commission_rule")
}

model CommissionEntry {
  id              String                @id @default(cuid())
  organizationId  String                @map("organization_id")
  professionalId  String                @map("professional_id")
  domain          CommissionDomain
  baseAmount      Int                   @map("base_amount") // Preço praticado do item, em centavos
  appliedType     CommissionType        @map("applied_type") // Como foi calculado
  appliedValue    Int                   @map("applied_value") // bps ou centavos, conforme appliedType
  commissionCents Int                   @map("commission_cents") // RESULTADO final, em centavos
  sourceLevel     Int                   @map("source_level") // 1 = exceção, 2 = default, 3 = casa
  status          CommissionEntryStatus @default(PENDING)
  appointmentId   String?               @map("appointment_id")
  // TODO: Add productId
  serviceId       String?               @map("service_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organizations Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  professionals Professionals @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  appointments  Appointments? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  services      Services?     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([organizationId, professionalId, createdAt])
  @@index([appointmentId])
  @@map("commission_entry")
}

// ---- AUDIT LOGS -------------------------------

model AuditLogs {
  id             String @id @default(cuid())
  entity         String
  entityId       String @map("entity_id")
  action         String
  userId         String @map("user_id")
  organizationId String @map("organization_id")
  changes        Json?

  createdAt DateTime @default(now()) @map("created_at")

  organizations Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([entity, entityId])
  @@map("audit_logs")
}

// ---- ENUMS ------------------------------------

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum MemberRole {
  OWNER
  MANAGER
  PROFESSIONAL
}

enum UserRole {
  CLIENT
  ADMIN
}

enum OrganizationAccessState {
  ACTIVE
  GRACE
  EXPIRED
  CANCELED
}

enum CommissionDomain {
  SERVICE
  PRODUCT
}

enum CommissionType {
  PERCENTAGE // value = basis points (4000 = 40%)
  FIXED // value = centavos (1500 = R$ 15,00)
}

enum CommissionEntryStatus {
  PENDING // atendimento concluído, comissão devida
  PAID // repassada ao profissional (fechamento)
  REVERSED // atendimento estornado/cancelado após conclusão
}
